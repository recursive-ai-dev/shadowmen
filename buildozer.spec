[app]
title = Shadow Men
package.name = shadowmen
package.domain = org.shadowmen
source.dir = .
source.include_exts = py,json,md
version = 0.1.0
requirements = python3,hostpython3,pycairo,pygobject

orientation = landscape
fullscreen = 1
